{
	"name": "@polarish/ai",
	"version": "0.1.2",
	"type": "module",
	"description": "Open-source SDK for building AI workflows where users bring their own AI subscriptions",
	"homepage": "https://github.com/tom2025b/polarish",
	"keywords": [
		"ai-sdk",
		"polarish",
		"ai",
		"claude-code",
		"codex",
		"typescript"
	],
	"imports": {
		"#tool-callback-host": {
			"types": "./dist/client/tool-callback-host.node.d.ts",
			"node": "./dist/client/tool-callback-host.node.js",
			"browser": "./dist/client/tool-callback-host.stub.js",
			"default": "./dist/client/tool-callback-host.node.js"
		}
	},
	"files": ["dist/**/*.js", "dist/**/*.d.ts", "README.md"],
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./openai-codex": {
			"types": "./dist/providers/openai-codex/index.d.ts",
			"import": "./dist/providers/openai-codex/index.js",
			"default": "./dist/providers/openai-codex/index.js"
		},
		"./anthropic-claude-code": {
			"types": "./dist/providers/anthropic-claude-code/index.d.ts",
			"import": "./dist/providers/anthropic-claude-code/index.js",
			"default": "./dist/providers/anthropic-claude-code/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "bun x tsc -p ./tsconfig.build.json",
		"lint": "bun x @biomejs/biome check index.ts types.ts client history runtime providers package.json tsconfig.json tsconfig.build.json",
		"typecheck": "bun x tsc -p ./tsconfig.json --noEmit",
		"prepublishOnly": "bun run lint && bun run typecheck && bun run build"
	},
	"peerDependencies": {
		"typescript": "^5",
		"zod": "^3.25 || ^4"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		}
	},
	"dependencies": {
		"effect": "^3.19.19",
		"openai": "^6.32.0",
		"zod-to-json-schema": "^3.25.1"
	},
	"devDependencies": {
		"@types/bun": "latest"
	}
}
