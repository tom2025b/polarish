{
	"name": "@polarish/cli",
	"version": "0.1.2",
	"description": "Polarish CLI — configure and run the local AI bridge",
	"type": "module",
	"homepage": "https://github.com/tom2025b/polarish",
	"repository": {
		"type": "git",
		"url": "https://github.com/tom2025b/polarish"
	},
	"bugs": {
		"url": "https://github.com/tom2025b/polarish/issues"
	},
	"keywords": ["cli", "polarish", "ai", "openai", "codex"],
	"files": ["bin", "dist", "public"],
	"bin": {
		"polarish": "./bin/run.js"
	},
	"oclif": {
		"bin": "polarish",
		"dirname": "polarish",
		"commands": "./dist/commands",
		"topicSeparator": " ",
		"hooks": {
			"init": "./dist/hooks/init.js",
			"postrun": "./dist/hooks/postrun.js"
		}
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"scripts": {
		"build": "rm -rf dist && tsc -p tsconfig.build.json",
		"lint": "biome check .",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"prepack": "bun run build"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@oclif/core": "^4.10.5",
		"inquirer": "^13.4.2",
		"nanospinner": "^1.2.2",
		"semver": "^7.7.4"
	},
	"devDependencies": {
		"@types/node": "^24.12.2",
		"@types/semver": "^7.7.1",
		"typescript": "~5.9.3"
	}
}
